{
  "name": "knowledge-as-infrastructure",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rm -rf _site && eleventy --config=eleventy.config.js && pagefind --site _site --glob \"**/*.html\"",
    "build:pdf": "./scripts/build-pdf.sh",
    "start": "eleventy --serve --config=eleventy.config.js --incremental"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11.14.0"
  },
  "devDependencies": {
    "@11ty/eleventy": "4.0.0-alpha.10",
    "@11ty/eleventy-plugin-rss": "^2.0.2",
    "@11ty/eleventy-plugin-syntaxhighlight": "5.0.2",
    "luxon": "^3.5.0",
    "pagefind": "^1.3.0"
  },
  "packageManager": "npm@12.0.0"
}
